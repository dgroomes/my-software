{
  "global": {
    "show_in_menu_bar": false
  },
  "profiles": [
    {
      "complex_modifications": {
        "rules": [
          {
            "description": "right_control + i to cmd + shift + open_bracket",
            "manipulators": [
              {
                "from": {
                  "key_code": "i",
                  "modifiers": {
                    "mandatory": [
                      "right_control"
                    ]
                  }
                },
                "to": [
                  {
                    "key_code": "open_bracket",
                    "modifiers": [
                      "left_command",
                      "left_shift"
                    ]
                  }
                ],
                "type": "basic"
              }
            ]
          },
          {
            "description": "right_control + o to cmd + shift + close_bracket",
            "manipulators": [
              {
                "from": {
                  "key_code": "o",
                  "modifiers": {
                    "mandatory": [
                      "right_control"
                    ]
                  }
                },
                "to": [
                  {
                    "key_code": "close_bracket",
                    "modifiers": [
                      "left_command",
                      "left_shift"
                    ]
                  }
                ],
                "type": "basic"
              }
            ]
          },
          {
            "description": "right_control + h to left_arrow",
            "manipulators": [
              {
                "from": {
                  "key_code": "h",
                  "modifiers": {
                    "mandatory": [
                      "right_control"
                    ],
                    "optional": [
                      "left_shift"
                    ]
                  }
                },
                "to": [
                  {
                    "key_code": "left_arrow"
                  }
                ],
                "type": "basic"
              }
            ]
          },
          {
            "description": "right_control + j to down_arrow",
            "manipulators": [
              {
                "from": {
                  "key_code": "j",
                  "modifiers": {
                    "mandatory": [
                      "right_control"
                    ],
                    "optional": [
                      "left_shift"
                    ]
                  }
                },
                "to": [
                  {
                    "key_code": "down_arrow"
                  }
                ],
                "type": "basic"
              }
            ]
          },
          {
            "description": "right_control + k to up_arrow",
            "manipulators": [
              {
                "from": {
                  "key_code": "k",
                  "modifiers": {
                    "mandatory": [
                      "right_control"
                    ],
                    "optional": [
                      "left_shift"
                    ]
                  }
                },
                "to": [
                  {
                    "key_code": "up_arrow"
                  }
                ],
                "type": "basic"
              }
            ]
          },
          {
            "description": "right_control + l to right_arrow",
            "manipulators": [
              {
                "from": {
                  "key_code": "l",
                  "modifiers": {
                    "mandatory": [
                      "right_control"
                    ],
                    "optional": [
                      "left_shift"
                    ]
                  }
                },
                "to": [
                  {
                    "key_code": "right_arrow"
                  }
                ],
                "type": "basic"
              }
            ]
          },
          {
            "description": "right_control + comma to option + left_arrow",
            "manipulators": [
              {
                "from": {
                  "key_code": "comma",
                  "modifiers": {
                    "mandatory": [
                      "right_control"
                    ],
                    "optional": [
                      "left_shift"
                    ]
                  }
                },
                "to": [
                  {
                    "key_code": "left_arrow",
                    "modifiers": [
                      "left_option"
                    ]
                  }
                ],
                "type": "basic"
              }
            ]
          },
          {
            "description": "right_control + period to option + right_arrow",
            "manipulators": [
              {
                "from": {
                  "key_code": "period",
                  "modifiers": {
                    "mandatory": [
                      "right_control"
                    ],
                    "optional": [
                      "left_shift"
                    ]
                  }
                },
                "to": [
                  {
                    "key_code": "right_arrow",
                    "modifiers": [
                      "left_option"
                    ]
                  }
                ],
                "type": "basic"
              }
            ]
          },
          {
            "description": "right_control + n to escape",
            "manipulators": [
              {
                "from": {
                  "key_code": "n",
                  "modifiers": {
                    "mandatory": [
                      "right_control"
                    ]
                  }
                },
                "to": [
                  {
                    "key_code": "escape"
                  }
                ],
                "type": "basic"
              }
            ]
          },
          {
            "description": "right_control + m to hyper (ctrl + cmd + shift + option) + m",
            "manipulators": [
              {
                "from": {
                  "key_code": "m",
                  "modifiers": {
                    "mandatory": [
                      "right_control"
                    ]
                  }
                },
                "to": [
                  {
                    "key_code": "m",
                    "modifiers": [
                      "left_control",
                      "left_command",
                      "left_option",
                      "left_shift"
                    ]
                  }
                ],
                "type": "basic"
              }
            ]
          },
          {
            "description": "shift + delete to forward delete",
            "manipulators": [
              {
                "from": {
                  "key_code": "delete_or_backspace",
                  "modifiers": {
                    "mandatory": [
                      "shift"
                    ],
                    "optional": [
                      "caps_lock",
                      "option"
                    ]
                  }
                },
                "to": [
                  {
                    "key_code": "delete_forward"
                  }
                ],
                "type": "basic"
              }
            ]
          },
          {
            "description": "Tab as a modifier (thank you https://github.com/pqrs-org/Karabiner-Elements/issues/831#issuecomment-343720386)",
            "manipulators": [
              {
                "from": {
                  "key_code": "tab"
                },
                "to": [
                  {
                    "set_variable": {
                      "name": "tab_modifier",
                      "value": 1
                    }
                  }
                ],
                "to_after_key_up": [
                  {
                    "set_variable": {
                      "name": "tab_modifier",
                      "value": 0
                    }
                  }
                ],
                "to_if_alone": [
                  {
                    "key_code": "tab"
                  }
                ],
                "type": "basic"
              }
            ]
          },
          {
            "description": "Open the browser (Safari) with 'tab + s'",
            "manipulators": [
              {
                "conditions": [
                  {
                    "name": "tab_modifier",
                    "type": "variable_if",
                    "value": 1
                  }
                ],
                "from": {
                  "key_code": "b"
                },
                "to": [
                  {
                    "shell_command": "open -a 'Safari.app'"
                  }
                ],
                "type": "basic"
              }
            ]
          },
          {
            "description": "Open the terminal (Ghostty) with 'tab + t'",
